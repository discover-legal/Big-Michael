{
  "name": "big-michael",
  "version": "0.1.0",
  "description": "Big Michael — portable multi-agent legal AI orchestration. Sits atop and within Mike OSS, Laverne, and others. DyTopo rounds, RuVector registry, Anthropic + Ollama inference, PyMuPDF/Camelot/Tesseract document tools, MCP + REST.",
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "seed": "tsx src/scripts/seed.ts",
    "smoke-test": "ANTHROPIC_API_KEY=smoke-test OPENAI_API_KEY=smoke-test tsx src/scripts/smoke-test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@qdrant/js-client-rest": "^1.12.0",
    "@tavily/core": "^0.7.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.0",
    "openai": "^4.67.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  }
}
